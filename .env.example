# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=4000
# Browser-facing app URL (no trailing slash). Set on Vercel for MoonPay/Rapyd return URLs (e.g. https://place-to-all-front.vercel.app).
# If unset, the API may use the browser Origin when it is allowed: see CORS_ORIGINS below, or https on *.vercel.app when CORS is empty.
# Local: http://localhost:3006
FRONTEND_URL=http://localhost:3006
# Optional aliases if FRONTEND_URL is unset: FRONTEND_ORIGIN, NEXT_PUBLIC_APP_URL

# Browser → this API (comma-separated exact origins). If set, only these origins get CORS and may be used as redirect base when FRONTEND_URL is missing.
# If empty, CORS allows any origin, and redirect base may be inferred from Origin only for https://*.vercel.app (custom domains still need FRONTEND_URL or list your origin here).
# Production: CORS_ORIGINS=https://place-to-all-front.vercel.app
# CORS_ORIGINS=http://localhost:3006

# MoonPay (buy flow: signed widget URL; get keys from MoonPay Dashboard)
MOONPAY_PUBLISHABLE_KEY=your-moonpay-publishable-key
MOONPAY_SECRET_KEY=your-moonpay-secret-key
MOONPAY_WEBHOOK_KEY=your-moonpay-webhook-secret
# Use sandbox for testing: MOONPAY_SANDBOX=true
# Optional: force demo placeholder wallet even when not sandbox (default off in production): MOONPAY_USE_DEMO_WALLET=true
# In sandbox, MoonPay sends ~1/100 on-chain; show receipt-equivalent: MOONPAY_SANDBOX_DISPLAY_MULTIPLIER=100
# Use MoonPay's built-in Ecosystem Fee (set % in MoonPay Dashboard) instead of app 8% on MoonPay purchases:
# MOONPAY_USE_ECOSYSTEM_FEE=true
# Set to false to allow changing fiat amount in the widget (default: amounts are locked when baseCurrencyAmount is sent):
# MOONPAY_LOCK_AMOUNT=false
# Optional: force every MoonPay buy to one wallet (signed URL locks widget; users cannot change it).
# EVM assets (ETH, USDT, USDC, …): use a single 0x address. Bitcoin: set MOONPAY_FIXED_BTC_ADDRESS instead/as well.
# MOONPAY_FIXED_WALLET_ADDRESS=0xYourTreasuryOrCustodyAddress...
# If unset, BTC uses a built-in lock address when the API uses MoonPay’s sandbox host (buy-sandbox…), or in dev/sandbox flags — so the widget does not ask for a wallet. Mainnet: set MOONPAY_FIXED_BTC_ADDRESS or MOONPAY_LOCK_BTC_WALLET=true for the default lock.
# MOONPAY_FIXED_BTC_ADDRESS=bc1...   (only used when currency is BTC)
# MOONPAY_LOCK_BTC_WALLET=true       (mainnet only: sign default lock when not using sandbox host; use with care)
#
# If unset, local dev (NODE_ENV=development), MoonPay sandbox (MOONPAY_SANDBOX=true), or MOONPAY_USE_DEMO_WALLET=true
# uses a built-in placeholder 0x address for EVM only so you can test without a treasury. Production: set a real address or MOONPAY_USE_DEMO_WALLET=false.

# Coinbase CDP (sandbox: https://portal.cdp.coinbase.com)
COINBASE_SANDBOX=true
COINBASE_API_KEY=
COINBASE_API_SECRET=
# Optional: if create wallet returns 404, Wallet API may be at a different base. Try:
# COINBASE_WALLET_BASE=https://sandbox.cdp.coinbase.com/platform
# COINBASE_WALLET_NETWORK=base-sepolia

# Etherscan (required when MOONPAY_SANDBOX=true for Sepolia balance/history; V1 deprecated)
# Get free key: https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=

# System fee: percent taken on buy, sell, transfer, MoonPay (0 = off, 8 = 8%)
SYSTEM_FEE_PERCENT=8
# Ledger fees (buy 4% admin slice + SYSTEM_FEE_PERCENT) credit this auth user's wallets. Default: lookup admin@admin.com.
ADMIN_OPERATOR_EMAIL=admin@admin.com
# Optional: pin fee recipient UUID instead of email lookup (e.g. if you use a non-email service account)
# SYSTEM_FEE_USER_ID=
# Secret to view collected fees: GET /api/system/fees with header X-Admin-Secret: <value>
ADMIN_SECRET=

# Real 92% user / 8% system wallet (on-chain). MoonPay sends to platform; we send 92% to user, 8% to fee address.
# Set all three to enable. ETH only (USDC/USDT stay ledger-only for now).
# PLATFORM_RECEIVES_MOONPAY=true
# PLATFORM_WALLET_ADDRESS=0x...   (address that receives MoonPay; must match private key)
# PLATFORM_WALLET_PRIVATE_KEY=0x... (to sign 92% + 8% sends; keep secret)
# FEE_COLLECTION_ADDRESS=0x...   (your system wallet where 8% is sent in real crypto)
# Optional RPC: SEPOLIA_RPC_URL=... (sandbox), BASE_RPC_URL=... (production)

# Reap card issuing (optional now; used for webhook signature validation)
# REAP_WEBHOOK_SECRET=replace-with-your-reap-webhook-secret
# REAP_API_KEY=your-sandbox-api-key
# REAP_BASE_URL=https://sandbox.api.caas.reap.global
# REAP_API_VERSION=v2.0
# Optional sandbox payload defaults for card issue:
# REAP_SANDBOX_COUNTRY=HKG
# REAP_SANDBOX_CITY=Hong Kong
# REAP_SANDBOX_ADDR_LINE1=Flat A on 1/F
# REAP_SANDBOX_ADDR_LINE2=123 Penny Lane
# REAP_SANDBOX_POSTAL_CODE=
# REAP_SANDBOX_BUSINESS_NAME=Place To All Limited
# REAP_SANDBOX_BUSINESS_REG_NO=ABC123456
# REAP_SANDBOX_CARD_NAME=PLACE TO ALL
# REAP_OTP_DIAL_CODE=852
# REAP_OTP_PHONE=95123456
# REAP_SANDBOX_SPEND_LIMIT=1000
